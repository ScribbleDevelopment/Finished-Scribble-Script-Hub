-- New file
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Scribble’s best",
    LoadingTitle = "Loading Hubs...",
    LoadingSubtitle = "by Scribble",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "ScribbleHubConfig",
        FileName = "Config"
    }
})

-- Mine Tab
local MineTab = Window:CreateTab("Mine", nil)
local MyHubs = {
    {Name = "Be Michael Jackson", URL = "https://raw.githubusercontent.com/ScribbleDevelopment/Scribble-hub/refs/heads/main/michael%20jackson"},
    {Name = "BRRD (Brain Rot Ripoff Destroyer)", URL = "https://raw.githubusercontent.com/ScribbleDevelopment/Scribble-hub/refs/heads/main/BRRD"},
    {Name = "Curtis Hub", URL = "https://raw.githubusercontent.com/8d5mj856pf-ship-it/Scribble-hub/refs/heads/main/curtis"},
    {Name = "flinky tool", URL = "https://raw.githubusercontent.com/8d5mj856pf-ship-it/Scribble-hub/refs/heads/main/flinky"},
    {Name = "holy visualz", URL = "https://raw.githubusercontent.com/8d5mj856pf-ship-it/Scribble-hub/refs/heads/main/holy%20visualz"},
    {Name = "spam random stuff", URL = "https://raw.githubusercontent.com/8d5mj856pf-ship-it/Scribble-hub/refs/heads/main/spam%20random%20stuff"},
    {Name = "univ3rse hub", URL = "https://raw.githubusercontent.com/8d5mj856pf-ship-it/Scribble-hub/refs/heads/main/univ3rse%20hub"},
    {Name = "Super Super op FLY SCRIPT YESS SUPER SIGMA", URL = "https://raw.githubusercontent.com/ScribbleDevelopment/Scribble-hub/refs/heads/main/op script hub"}
}

for _, hub in pairs(MyHubs) do
    MineTab:CreateButton({
        Name = hub.Name,
        Callback = function()
            -- Automatically encodes spaces into %20 safely before requesting
            local cleanURL = string.gsub(hub.URL, " ", "%%20")
            local success, err = pcall(function()
                loadstring(game:HttpGet(cleanURL))()
            end)
            if not success then
                warn("Failed to load " .. hub.Name .. ". Error: " .. tostring(err))
            end
        end,
    })
end

